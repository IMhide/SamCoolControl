#!/usr/bin/env bash
#
# memory - lightweight file-based RAG engine for the typed memory
#
# The memory lives as atomic Markdown cards with YAML frontmatter, in two scopes:
#   - GLOBAL : memory/<type>/NNNN-*.md          (universal Coolify knowledge)
#   - INFRA  : infras/<active>/<type>/NNNN-*.md  (server-specific, local)
# where <type> is one of: decisions architecture habits cookbook incidents.
#
# Usage:
#   memory search <terms...>              Search cards (global + active infra), ranked
#   memory new <type> <scope> <title...>  Create a card (scope: global | infra), update INDEX
#   memory reindex [type] [scope]         Rebuild INDEX.md files from card frontmatter
#
# Notes:
#   - <type> accepts singular or plural (decision/decisions, etc.)
#   - INDEX.md files are never treated as cards.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MEMORY_DIR="$PROJECT_ROOT/memory"
INFRAS_DIR="$PROJECT_ROOT/infras"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; BOLD='\033[1m'; DIM='\033[2m'; CYAN='\033[0;36m'; NC='\033[0m'
_err()  { echo -e "${RED}$*${NC}" >&2; }
_ok()   { echo -e "${GREEN}$*${NC}"; }
_dim()  { echo -e "${DIM}$*${NC}"; }

TYPES=(decisions architecture habits cookbook incidents)

# --- profile resolution (same order as coolify-api.sh) ---
_active_infra() {
    if [[ -n "${COOLIFY_PROFILE:-}" ]]; then printf '%s' "$COOLIFY_PROFILE"; return 0; fi
    local f="$INFRAS_DIR/.current"
    [[ -f "$f" ]] && tr -d '[:space:]' < "$f" || printf ''
}

# Normalize a type argument (singular -> plural dir name). Echoes "" if invalid.
_norm_type() {
    case "${1:-}" in
        decision|decisions)        printf 'decisions' ;;
        architecture|architectures) printf 'architecture' ;;
        habit|habits)              printf 'habits' ;;
        cookbook|cookbooks)        printf 'cookbook' ;;
        incident|incidents)        printf 'incidents' ;;
        *)                         printf '' ;;
    esac
}

# Singular "type:" frontmatter value for a given dir name.
_singular_type() {
    case "$1" in
        decisions) printf 'decision' ;;
        architecture) printf 'architecture' ;;
        habits) printf 'habit' ;;
        cookbook) printf 'cookbook' ;;
        incidents) printf 'incident' ;;
        *) printf '%s' "$1" ;;
    esac
}

# Extract a top-level scalar frontmatter field (between the first two '---').
# Usage: _fm_field <file> <key>
_fm_field() {
    awk -v key="$2" '
        BEGIN { infm=0 }
        NR==1 && $0=="---" { infm=1; next }
        infm && $0=="---" { exit }
        infm {
            # match "key:" at start
            if ($0 ~ "^"key":[ \t]*") {
                sub("^"key":[ \t]*", "", $0)
                # strip surrounding quotes and brackets for display
                gsub(/^["'\'']|["'\'']$/, "", $0)
                print $0
                exit
            }
        }
    ' "$1"
}

# A card is any .md under a type dir whose name is not INDEX.md
_is_card() {
    local base; base="$(basename "$1")"
    [[ "$base" != "INDEX.md" && "$base" == *.md ]]
}

# -------------------------------------------------------------------------
# search
# -------------------------------------------------------------------------
cmd_search() {
    [[ $# -ge 1 ]] || { _err "Usage: memory search <terms...>"; return 1; }
    local query="$*"
    local active; active="$(_active_infra)"

    # Build the list of roots to search.
    local -a roots=("$MEMORY_DIR")
    if [[ -n "$active" && -d "$INFRAS_DIR/$active" ]]; then
        roots+=("$INFRAS_DIR/$active")
    fi

    echo -e "${BOLD}memory search:${NC} ${query}   ${DIM}(global${active:+ + infra:$active})${NC}"
    echo

    # Collect matches into two buckets: frontmatter (title/tags) vs body.
    local -a fm_hits=() body_hits=()
    local root type dir f
    for root in "${roots[@]}"; do
        for type in "${TYPES[@]}"; do
            dir="$root/$type"
            [[ -d "$dir" ]] || continue
            for f in "$dir"/*.md; do
                [[ -e "$f" ]] || continue
                _is_card "$f" || continue
                # case-insensitive match anywhere?
                if grep -qi -- "$query" "$f"; then
                    # does it match in title or tags (frontmatter)?
                    local title tags
                    title="$(_fm_field "$f" title)"
                    tags="$(_fm_field "$f" tags)"
                    if printf '%s\n%s\n' "$title" "$tags" | grep -qi -- "$query"; then
                        fm_hits+=("$f")
                    else
                        body_hits+=("$f")
                    fi
                fi
            done
        done
    done

    local total=$(( ${#fm_hits[@]} + ${#body_hits[@]} ))
    if [[ "$total" -eq 0 ]]; then
        _dim "No matching cards."
        return 0
    fi

    _print_hit() {
        local f="$1"
        local rel="${f#$PROJECT_ROOT/}"
        local scope type_dir id title
        scope="$(_fm_field "$f" scope)"; [[ -n "$scope" ]] || scope="?"
        type_dir="$(basename "$(dirname "$f")")"
        id="$(_fm_field "$f" id)"; [[ -n "$id" ]] || id="????"
        title="$(_fm_field "$f" title)"; [[ -n "$title" ]] || title="(untitled)"
        printf '  %b%s/%s/%s%b  %s\n' "$CYAN" "$scope" "$type_dir" "$id" "$NC" "$title"
        printf '      %b%s%b\n' "$DIM" "$rel" "$NC"
    }

    if [[ ${#fm_hits[@]} -gt 0 ]]; then
        _ok "Most relevant (title/tags match):"
        for f in "${fm_hits[@]}"; do _print_hit "$f"; done
        echo
    fi
    if [[ ${#body_hits[@]} -gt 0 ]]; then
        echo -e "${BOLD}Also matched (body):${NC}"
        for f in "${body_hits[@]}"; do _print_hit "$f"; done
    fi
}

# -------------------------------------------------------------------------
# new
# -------------------------------------------------------------------------
_slugify() {
    # lowercase, strip accents best-effort, non-alnum -> '-', squeeze, trim
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

# Next zero-padded id in a type dir (max existing + 1).
_next_id() {
    local dir="$1" max=0 f base num
    for f in "$dir"/*.md; do
        [[ -e "$f" ]] || continue
        base="$(basename "$f")"
        [[ "$base" == "INDEX.md" ]] && continue
        num="${base%%-*}"
        if [[ "$num" =~ ^[0-9]+$ ]]; then
            num=$((10#$num))
            (( num > max )) && max=$num
        fi
    done
    printf '%04d' $(( max + 1 ))
}

cmd_new() {
    local type_arg="${1:?Usage: memory new <type> <scope> <title...>}"
    local scope_arg="${2:?Usage: memory new <type> <scope> <title...>}"
    shift 2
    [[ $# -ge 1 ]] || { _err "Usage: memory new <type> <scope> <title...>"; return 1; }
    local title="$*"

    local type; type="$(_norm_type "$type_arg")"
    [[ -n "$type" ]] || { _err "Invalid type '$type_arg'. Use: decision|architecture|habit|cookbook|incident"; return 1; }

    # Resolve target directory + scope label
    local base_dir scope_label
    case "$scope_arg" in
        global)
            base_dir="$MEMORY_DIR/$type"
            scope_label="global"
            ;;
        infra|infra:*)
            local infra_name="${scope_arg#infra:}"
            [[ "$infra_name" == "infra" ]] && infra_name="$(_active_infra)"
            [[ -n "$infra_name" ]] || { _err "No active infra. Use 'infra:<name>' or set one with ./scripts/infra use <name>."; return 1; }
            [[ -d "$INFRAS_DIR/$infra_name" ]] || { _err "Infra '$infra_name' not found ($INFRAS_DIR/$infra_name)."; return 1; }
            base_dir="$INFRAS_DIR/$infra_name/$type"
            scope_label="infra:$infra_name"
            ;;
        *)
            _err "Invalid scope '$scope_arg'. Use: global | infra | infra:<name>"; return 1 ;;
    esac

    mkdir -p "$base_dir"
    local id slug file
    id="$(_next_id "$base_dir")"
    slug="$(_slugify "$title")"
    [[ -n "$slug" ]] || slug="card"
    file="$base_dir/${id}-${slug}.md"

    local today; today="$(date +%Y-%m-%d)"
    local singular; singular="$(_singular_type "$type")"

    # Section heading depends on type
    local section
    case "$type" in
        decisions)    section="Décision" ;;
        architecture) section="Montage" ;;
        habits)       section="Règle" ;;
        cookbook)     section="Procédure" ;;
        incidents)    section="Incident & Fix" ;;
        *)            section="Détails" ;;
    esac

    cat > "$file" <<EOF
---
id: ${id}
type: ${singular}
scope: ${scope_label}
title: ${title}
tags: []
date: ${today}
status: active
related: []
---

## Contexte


## ${section}


## Pourquoi / Conséquences

EOF

    _ok "Created: ${file#$PROJECT_ROOT/}"
    # Update the INDEX for this dir
    _reindex_dir "$base_dir" "$scope_label" >/dev/null
    _dim "INDEX updated: ${base_dir#$PROJECT_ROOT/}/INDEX.md"
    # Echo the path on stdout (last line) so callers/skills can capture it
    printf '%s\n' "$file"
}

# -------------------------------------------------------------------------
# reindex
# -------------------------------------------------------------------------
# Rebuild a single dir's INDEX.md from its cards' frontmatter.
_reindex_dir() {
    local dir="$1" scope_label="$2"
    [[ -d "$dir" ]] || return 0
    local type_dir; type_dir="$(basename "$dir")"
    local index="$dir/INDEX.md"

    # Human title for the type
    local htitle
    case "$type_dir" in
        decisions) htitle="Decisions" ;;
        architecture) htitle="Architecture" ;;
        habits) htitle="Habits" ;;
        cookbook) htitle="Cookbook" ;;
        incidents) htitle="Incidents" ;;
        *) htitle="$type_dir" ;;
    esac

    {
        printf '# %s — INDEX (%s)\n\n' "$htitle" "$scope_label"
        printf '| id | titre | tags | date | status |\n'
        printf '|----|-------|------|------|--------|\n'
        # rows, sorted by id
        local f
        for f in $(ls "$dir"/*.md 2>/dev/null | sort); do
            local base; base="$(basename "$f")"
            [[ "$base" == "INDEX.md" ]] && continue
            local id title tags date status
            id="$(_fm_field "$f" id)"
            title="$(_fm_field "$f" title)"
            tags="$(_fm_field "$f" tags)"
            date="$(_fm_field "$f" date)"
            status="$(_fm_field "$f" status)"
            # normalize tags: strip [ ] and quotes already handled; keep as-is
            tags="$(printf '%s' "$tags" | sed -E 's/^\[//; s/\]$//')"
            printf '| %s | %s | %s | %s | %s |\n' \
                "${id:-?}" "${title:-?}" "${tags:-}" "${date:-}" "${status:-}"
        done
    } > "$index"
    echo "$index"
}

cmd_reindex() {
    local only_type="${1:-}" only_scope="${2:-}"
    local norm=""
    if [[ -n "$only_type" ]]; then
        norm="$(_norm_type "$only_type")"
        [[ -n "$norm" ]] || { _err "Invalid type '$only_type'."; return 1; }
    fi

    # Which roots? global always; infra(s) depending on scope filter.
    local -a scope_specs=()   # each: "label|rootdir"
    if [[ -z "$only_scope" || "$only_scope" == "global" ]]; then
        scope_specs+=("global|$MEMORY_DIR")
    fi
    if [[ -z "$only_scope" || "$only_scope" == infra* ]]; then
        local infra_name=""
        if [[ "$only_scope" == infra:* ]]; then
            infra_name="${only_scope#infra:}"
        elif [[ "$only_scope" == "infra" || -z "$only_scope" ]]; then
            infra_name="$(_active_infra)"
        fi
        if [[ -n "$infra_name" && -d "$INFRAS_DIR/$infra_name" ]]; then
            scope_specs+=("infra:$infra_name|$INFRAS_DIR/$infra_name")
        fi
    fi

    local count=0 spec label root type
    for spec in "${scope_specs[@]}"; do
        label="${spec%%|*}"; root="${spec#*|}"
        for type in "${TYPES[@]}"; do
            [[ -n "$norm" && "$type" != "$norm" ]] && continue
            [[ -d "$root/$type" ]] || continue
            _reindex_dir "$root/$type" "$label" >/dev/null
            count=$((count+1))
        done
    done
    _ok "Reindexed $count INDEX.md file(s)."
}

usage() {
    cat <<'HELP'
memory - file-based RAG for the typed memory

USAGE:
    memory search <terms...>               Search cards (global + active infra)
    memory new <type> <scope> <title...>   Create a card; <scope>=global|infra|infra:<name>
    memory reindex [type] [scope]          Rebuild INDEX.md from card frontmatter

TYPES: decision | architecture | habit | cookbook | incident
HELP
}

main() {
    local cmd="${1:-help}"
    shift || true
    case "$cmd" in
        search|find|s)  cmd_search "$@" ;;
        new|create|n)   cmd_new "$@" ;;
        reindex|index)  cmd_reindex "$@" ;;
        help|-h|--help) usage ;;
        *)              _err "Unknown command: $cmd"; usage; exit 1 ;;
    esac
}

main "$@"
