#!/usr/bin/env bash
#
# coolify - High-level CLI to manage a Coolify server
#
# Usage:
#   coolify servers                  List all servers
#   coolify apps                     List all applications
#   coolify app <uuid>               Get application details
#   coolify app:start <uuid>         Start an application
#   coolify deploy <uuid>            Deploy an application
#   coolify status                   Quick overview of everything
#
# Requires: curl, jq

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/coolify-api.sh"

# ---------------------------------------------------------------------------
# Colors & formatting
# ---------------------------------------------------------------------------

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

_header()  { echo -e "\n${BOLD}${BLUE}=== $* ===${NC}\n"; }
_success() { echo -e "${GREEN}$*${NC}"; }
_warn()    { echo -e "${YELLOW}$*${NC}"; }
_error()   { echo -e "${RED}$*${NC}" >&2; }
_dim()     { echo -e "${DIM}$*${NC}"; }

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_help() {
    cat <<'HELP'
Coolify Control CLI

USAGE:
    coolify [--infra <name>] <command> [arguments]

GLOBAL OPTIONS:
    --infra <name>              Target a specific infra/profile for this call
                                (overrides infras/.current and COOLIFY_PROFILE).
                                See: ./scripts/infra list

SERVER COMMANDS:
    servers                     List all servers
    server <uuid>               Get server details
    server:resources <uuid>     List resources on a server
    server:domains <uuid>       List domains on a server
    server:validate <uuid>      Validate server connectivity

APPLICATION COMMANDS:
    apps                        List all applications
    app <uuid>                  Get application details
    app:start <uuid>            Start an application
    app:stop <uuid>             Stop an application
    app:restart <uuid>          Restart an application
    app:logs <uuid>             Get application logs
    app:envs <uuid>             List environment variables
    app:env:set <uuid> <k> <v>  Set an environment variable

DATABASE COMMANDS:
    databases                   List all databases
    db <uuid>                   Get database details
    db:start <uuid>             Start a database
    db:stop <uuid>              Stop a database
    db:restart <uuid>           Restart a database

SERVICE COMMANDS:
    services                    List all services
    service <uuid>              Get service details
    service:start <uuid>        Start a service
    service:stop <uuid>         Stop a service
    service:restart <uuid>      Restart a service
    service:envs <uuid>         List environment variables

PROJECT COMMANDS:
    projects                    List all projects
    project <uuid>              Get project details
    project:envs <uuid>         List project environments

DEPLOYMENT COMMANDS:
    deployments                 List recent deployments
    deployment <uuid>           Get deployment details
    deploy <uuid> [--force]     Deploy an application
    deploy:tag <tag> [--force]  Deploy by tag

OTHER COMMANDS:
    resources                   List all resources
    teams                       List teams
    team                        Current team info
    keys                        List SSH private keys
    version                     Coolify API version
    health                      Health check
    status                      Quick overview dashboard
    raw <METHOD> <PATH> [BODY]  Raw API call

HELP
}

cmd_servers() {
    _header "Servers"
    coolify_servers_list | jq -r '
        .[] | "  \(.uuid)  \(.name // "unnamed")  \(.ip // "n/a")  \(if .settings.is_reachable then "REACHABLE" else "UNREACHABLE" end)"
    ' 2>/dev/null || coolify_servers_list
}

cmd_server()            { coolify_server_get "$1"; }
cmd_server_resources()  { coolify_server_resources "$1"; }
cmd_server_domains()    { coolify_server_domains "$1"; }
cmd_server_validate()   { coolify_server_validate "$1"; }

cmd_apps() {
    _header "Applications"
    coolify_apps_list | jq -r '
        .[] | "  \(.uuid)  \(.name // "unnamed")  \(.status // "unknown")  \(.fqdn // "")"
    ' 2>/dev/null || coolify_apps_list
}

cmd_app()         { coolify_app_get "$1"; }
cmd_app_start()   { coolify_app_start "$1"; _success "Application $1 starting..."; }
cmd_app_stop()    { coolify_app_stop "$1"; _success "Application $1 stopping..."; }
cmd_app_restart() { coolify_app_restart "$1"; _success "Application $1 restarting..."; }
cmd_app_logs()    { coolify_app_logs "$1"; }
cmd_app_envs()    { coolify_app_envs "$1"; }
cmd_app_env_set() {
    local uuid="${1:?uuid required}"
    local key="${2:?key required}"
    local value="${3:?value required}"
    local preview="${4:-false}"
    local build="${5:-false}"
    coolify_api POST "/applications/$uuid/envs" \
        "$(jq -n --arg k "$key" --arg v "$value" --argjson p "$preview" --argjson b "$build" \
        '{key: $k, value: $v, is_preview: $p, is_build_time: $b}')"
    _success "Env $key set on $uuid"
}

cmd_databases() {
    _header "Databases"
    coolify_databases_list | jq -r '
        .[] | "  \(.uuid)  \(.name // "unnamed")  \(.type // "unknown")  \(.status // "unknown")"
    ' 2>/dev/null || coolify_databases_list
}

cmd_db()         { coolify_database_get "$1"; }
cmd_db_start()   { coolify_database_start "$1"; _success "Database $1 starting..."; }
cmd_db_stop()    { coolify_database_stop "$1"; _success "Database $1 stopping..."; }
cmd_db_restart() { coolify_database_restart "$1"; _success "Database $1 restarting..."; }

cmd_services() {
    _header "Services"
    coolify_services_list | jq -r '
        .[] | "  \(.uuid)  \(.name // "unnamed")  \(.status // "unknown")"
    ' 2>/dev/null || coolify_services_list
}

cmd_service()         { coolify_service_get "$1"; }
cmd_service_start()   { coolify_service_start "$1"; _success "Service $1 starting..."; }
cmd_service_stop()    { coolify_service_stop "$1"; _success "Service $1 stopping..."; }
cmd_service_restart() { coolify_service_restart "$1"; _success "Service $1 restarting..."; }
cmd_service_envs()    { coolify_service_envs "$1"; }

cmd_projects() {
    _header "Projects"
    coolify_projects_list | jq -r '
        .[] | "  \(.uuid)  \(.name // "unnamed")  \(.description // "")"
    ' 2>/dev/null || coolify_projects_list
}

cmd_project()      { coolify_project_get "$1"; }
cmd_project_envs() { coolify_project_envs "$1"; }

cmd_deployments() {
    _header "Recent Deployments"
    coolify_deployments_list | jq -r '
        .[] | "  \(.uuid)  \(.status // "unknown")  \(.created_at // "")"
    ' 2>/dev/null || coolify_deployments_list
}

cmd_deployment() { coolify_deployment_get "$1"; }

cmd_deploy() {
    local uuid="${1:?uuid required}"
    local force="false"
    [[ "${2:-}" == "--force" ]] && force="true"
    coolify_deploy "$uuid" "$force"
    _success "Deployment triggered for $uuid"
}

cmd_deploy_tag() {
    local tag="${1:?tag required}"
    local force="false"
    [[ "${2:-}" == "--force" ]] && force="true"
    coolify_deploy_by_tag "$tag" "$force"
    _success "Deployment triggered for tag: $tag"
}

cmd_resources()  { coolify_resources_list; }
cmd_teams()      { coolify_teams_list; }
cmd_team()       { coolify_team_current; }
cmd_keys()       { coolify_keys_list; }
cmd_version()    { coolify_version; }
cmd_health()     { coolify_healthcheck; }

cmd_status() {
    _header "Coolify Status Dashboard"

    # Load env up front so we can show which infra/base_url we're talking to.
    _coolify_load_env 2>/dev/null || true
    local _profile
    _profile="$(_coolify_resolve_profile)"
    if [[ -n "$_profile" ]]; then
        _dim "infra: $_profile  (${COOLIFY_BASE_URL:-?})"
    else
        _dim "infra: (none - using root .env)  (${COOLIFY_BASE_URL:-?})"
    fi
    echo

    echo -e "${CYAN}Version:${NC}"
    coolify_version 2>/dev/null | jq -r '."version" // .version // .' 2>/dev/null || echo "  (unable to fetch)"
    echo

    echo -e "${CYAN}Servers:${NC}"
    coolify_servers_list 2>/dev/null | jq -r '
        .[] | "  [\(if .settings.is_reachable then "OK" else "!!" end)] \(.name // .uuid) (\(.ip // "n/a"))"
    ' 2>/dev/null || echo "  (unable to fetch)"
    echo

    echo -e "${CYAN}Applications:${NC}"
    coolify_apps_list 2>/dev/null | jq -r '
        .[] | "  [\(.status // "?")] \(.name // .uuid) \(.fqdn // "")"
    ' 2>/dev/null || echo "  (unable to fetch)"
    echo

    echo -e "${CYAN}Databases:${NC}"
    coolify_databases_list 2>/dev/null | jq -r '
        .[] | "  [\(.status // "?")] \(.name // .uuid) (\(.type // "?"))"
    ' 2>/dev/null || echo "  (unable to fetch)"
    echo

    echo -e "${CYAN}Services:${NC}"
    coolify_services_list 2>/dev/null | jq -r '
        .[] | "  [\(.status // "?")] \(.name // .uuid)"
    ' 2>/dev/null || echo "  (unable to fetch)"
    echo

    echo -e "${CYAN}Recent Deployments:${NC}"
    coolify_deployments_list 2>/dev/null | jq -r '
        .[:5][] | "  [\(.status // "?")] \(.uuid) \(.created_at // "")"
    ' 2>/dev/null || echo "  (unable to fetch)"
}

cmd_raw() { coolify_api "$@"; }

# ---------------------------------------------------------------------------
# Router
# ---------------------------------------------------------------------------

main() {
    # --- Global flag: --infra <name> (may appear anywhere before the args) ---
    # Intercept it, export COOLIFY_PROFILE, and strip it from the argument list.
    local -a args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --infra)
                [[ -n "${2:-}" ]] || { _error "--infra requires an infra name"; exit 1; }
                export COOLIFY_PROFILE="$2"
                shift 2
                ;;
            --infra=*)
                export COOLIFY_PROFILE="${1#--infra=}"
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done
    set -- "${args[@]}"

    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        help|--help|-h)         cmd_help ;;
        servers)                cmd_servers ;;
        server)                 cmd_server "$@" ;;
        server:resources)       cmd_server_resources "$@" ;;
        server:domains)         cmd_server_domains "$@" ;;
        server:validate)        cmd_server_validate "$@" ;;
        apps|applications)      cmd_apps ;;
        app)                    cmd_app "$@" ;;
        app:start)              cmd_app_start "$@" ;;
        app:stop)               cmd_app_stop "$@" ;;
        app:restart)            cmd_app_restart "$@" ;;
        app:logs)               cmd_app_logs "$@" ;;
        app:envs)               cmd_app_envs "$@" ;;
        app:env:set)            cmd_app_env_set "$@" ;;
        databases|dbs)          cmd_databases ;;
        db|database)            cmd_db "$@" ;;
        db:start)               cmd_db_start "$@" ;;
        db:stop)                cmd_db_stop "$@" ;;
        db:restart)             cmd_db_restart "$@" ;;
        services)               cmd_services ;;
        service)                cmd_service "$@" ;;
        service:start)          cmd_service_start "$@" ;;
        service:stop)           cmd_service_stop "$@" ;;
        service:restart)        cmd_service_restart "$@" ;;
        service:envs)           cmd_service_envs "$@" ;;
        projects)               cmd_projects ;;
        project)                cmd_project "$@" ;;
        project:envs)           cmd_project_envs "$@" ;;
        deployments)            cmd_deployments ;;
        deployment)             cmd_deployment "$@" ;;
        deploy)                 cmd_deploy "$@" ;;
        deploy:tag)             cmd_deploy_tag "$@" ;;
        resources)              cmd_resources ;;
        teams)                  cmd_teams ;;
        team)                   cmd_team ;;
        keys)                   cmd_keys ;;
        version)                cmd_version ;;
        health)                 cmd_health ;;
        status)                 cmd_status ;;
        raw)                    cmd_raw "$@" ;;
        *)                      _error "Unknown command: $cmd"; cmd_help; exit 1 ;;
    esac
}

main "$@"
